# But keep directory structure and READMEs
!/data/raw/.gitkeep
!/data/interim/.gitkeep
!/data/processed/.gitkeep
!/data/validation/.gitkeep
!/data/tracks/**/.gitkeep
!/data/predictions/.gitkeep
